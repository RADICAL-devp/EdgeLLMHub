    end

    subgraph JavaBE[clinical-intelligence — Micronaut]
        Ingest[Ingestion: reactive endpoints]
        Pipeline[Pipeline: STT -> Translate -> LLM structuring -> Vectorize]
        Ingest --> Pipeline
    end

    Data1 -->|Dio + REST, not a package dependency| API
